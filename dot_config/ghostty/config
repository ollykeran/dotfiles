# https://github.com/imrajyavardhan12/spectre-ghostty-config

# Fonts
font-size = 15
font-family = MartianMono NF 

# Mouse
mouse-hide-while-typing = true

# Clipboard
clipboard-write = allow
copy-on-select = clipboard

# Shell
command = /opt/homebrew/bin/fish
shell-integration-features = cursor,no-sudo,title,ssh-env,ssh-terminfo

# Application
notify-on-command-finish-action = no-bell,no-notify
maximize = true
quit-after-last-window-closed = true
confirm-close-surface = false
bell-audio-volume = 0

# Macos
macos-icon = holographic
macos-icon-frame = chrome
auto-update = download

